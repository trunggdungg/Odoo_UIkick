<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- HOME PAGE (danh sách project + sidebar filter)                -->
    <!-- ============================================================ -->
    <template id="home_page" name="UIKick - Discover">
        <t t-call="web.frontend_layout">
            <t t-set="title" t-value="(header_label or '') + ' — Kickstarter'"/>
            <div id="wrap" class="uikick">

                <div class="uikick-body">
                    <!-- Sidebar filters -->
                    <button type="button" id="uikick-filter-toggle" class="uikick-filter-toggle">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12h12M3 6h18M9 18h6"/>
                        </svg>
                        Filter by
                        <svg class="uikick-filter-toggle-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <form method="get" action="/uikick" id="uikick-filter-form" class="uikick-sidebar">
                        <p class="uikick-sidebar-title">Filter by</p>
                        <input type="hidden" name="categories_submitted" value="1"/>

                        <div class="uikick-filter-group">
                            <h3>Category</h3>
                            <div class="uikick-category-list">
                                <t t-foreach="categories" t-as="cat">
                                    <label class="uikick-check-row uikick-cat-check-row">
                                        <span>
                                            <input type="checkbox" name="category" t-att-value="cat"
                                                   t-att-checked="'checked' if cat in filters['categories'] else None"/>
                                            <t t-esc="cat"/>
                                        </span>
                                    </label>
                                </t>
                            </div>
                        </div>

                        <hr/>

                        <div class="uikick-filter-group">
                            <h3>Project status</h3>
                            <label class="uikick-check-row">
                                <span>
                                    <input type="checkbox" name="status" value="upcoming"
                                           t-att-checked="'checked' if 'upcoming' in filters['status'] else None"/>
                                    Upcoming
                                </span>
                                <span class="uikick-count">10,285</span>
                            </label>
                            <label class="uikick-check-row">
                                <span>
                                    <input type="checkbox" name="status" value="live"
                                           t-att-checked="'checked' if 'live' in filters['status'] else None"/>
                                    Live
                                </span>
                                <span class="uikick-count">2,933</span>
                            </label>
                            <!-- "Late pledge"/"Include ended" have no matching status value in uikick.project yet,
                                 so they stay decorative like in the original React mock. -->
                            <label class="uikick-check-row">
                                <span><input type="checkbox" name="late_pledge" value="1"/> Late pledge</span>
                                <span class="uikick-count">4,731</span>
                            </label>
                            <label class="uikick-check-row uikick-check-row-single">
                                <input type="checkbox" name="include_ended" value="1"/> Include ended projects
                            </label>
                        </div>

                        <hr/>

                        <div class="uikick-filter-group">
                            <h3>Location</h3>
                            <input type="text" name="location" placeholder="Search by city, state, country..."
                                   class="uikick-input" t-att-value="filters['location']"/>
                            <select class="uikick-select">
                                <option>Anywhere</option>
                                <option>Vietnam</option>
                                <option>Hanoi, Viet Nam</option>
                                <option>United States</option>
                                <option>United Kingdom</option>
                                <option>Canada</option>
                            </select>
                        </div>

                        <button type="submit" class="uikick-btn-primary uikick-btn-block uikick-filter-apply">Apply filters</button>
                    </form>

                    <!-- Main content -->
                    <main class="uikick-main">
                        <div class="uikick-main-header">
                            <div>
                                <h1><t t-esc="header_label"/></h1>
                                <p><t t-esc="len(projects)"/> projects</p>
                            </div>
                            <div class="uikick-sort">
                                <span>Sort by</span>
                                <select class="uikick-select" id="uikick-sort-select" name="sort" form="uikick-filter-form">
                                    <t t-foreach="sort_options" t-as="opt">
                                        <option t-att-value="opt" t-att-selected="'selected' if filters['sort'] == opt else None">
                                            <t t-esc="opt"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                        </div>

                        <div class="uikick-grid">
                            <t t-foreach="projects" t-as="project">
                                <a t-att-href="'/uikick/project/' + project.project_code" class="uikick-card">
                                    <div class="uikick-card-media">
                                        <img t-att-src="project.image" t-att-alt="project.title"
                                             class="uikick-card-img"/>
                                        <video t-att-src="project.video_url" muted="muted" loop="loop"
                                               playsinline="playsinline" preload="metadata"
                                               class="uikick-card-video"/>
                                        <t t-if="project.status == 'upcoming'">
                                            <span class="uikick-badge">Upcoming</span>
                                        </t>
                                    </div>
                                    <div class="uikick-card-body">
                                        <p class="uikick-card-category"><t t-esc="project.category"/></p>
                                        <h3 class="uikick-card-title"><t t-esc="project.title"/></h3>
                                        <p class="uikick-card-creator">by <span><t t-esc="project.creator"/></span></p>

                                        <div class="uikick-card-location">
                                            <svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" clip-rule="evenodd"
                                                      d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"/>
                                            </svg>
                                            <span><t t-esc="project.location"/></span>
                                        </div>
                                    </div>
                                </a>
                            </t>
                            <t t-if="not projects">
                                <p class="uikick-empty">No projects match these filters.</p>
                            </t>
                        </div>
                    </main>
                </div>
            </div>
        </t>
    </template>


    <!-- ============================================================ -->
    <!-- DETAIL PAGE (chi tiết chiến dịch)                             -->
    <!-- ============================================================ -->
    <template id="detail_page" name="UIKick - Campaign Detail">
        <t t-call="web.frontend_layout">
            <t t-set="title" t-value="(project.title or '') + ' — Kickstarter'"/>
            <div id="wrap" class="uikick uikick-detail">

                <!-- Breadcrumb -->
                <nav class="uikick-breadcrumb">
                    <div class="uikick-container">
                        <a href="/uikick">Khám phá</a>
                        <span class="uikick-breadcrumb-sep">›</span>
                        <a t-att-href="'/uikick/category/' + project.category"><t t-esc="project.category"/></a>
                        <span class="uikick-breadcrumb-sep">›</span>
                        <span class="uikick-breadcrumb-current"><t t-esc="project.title"/></span>
                    </div>
                </nav>

                <!-- Hero title -->
                <div class="uikick-detail-hero">
                    <div class="uikick-container">
                        <h1><t t-esc="project.title"/></h1>
                        <p class="uikick-detail-desc"><t t-esc="project.description"/></p>
                    </div>
                </div>

                <!-- Hero media: video (left) + pledge sidebar (right), matching real Kickstarter campaign pages -->
                <div class="uikick-hero-media">
                    <div class="uikick-container uikick-hero-row">
                        <div class="uikick-hero-video-col">
                            <div class="uikick-hero-video" id="uikick-hero-video">
                                <video t-att-src="project.video_url" muted="muted" loop="loop" playsinline="playsinline"
                                       class="uikick-hero-video-el"/>
                                <div class="uikick-hero-play-overlay">
                                    <div class="uikick-hero-play-circle">
                                        <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    </div>
                                </div>
                                <div class="uikick-hero-pause-overlay">
                                    <svg width="14" height="14" fill="white" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                                </div>
                                <div class="uikick-hero-text-overlay">
                                    <t t-if="project.campaign_number">
                                        <div class="uikick-hero-campaign-num">
                                            SẢN PHẨM THỨ <t t-esc="str(project.campaign_number)"/>.
                                        </div>
                                    </t>
                                    <div class="uikick-hero-total">
                                        <t t-if="project.status == 'ended'">Dự án đã hoàn thành.</t>
                                        <t t-elif="project.status == 'upcoming'">Sắp ra mắt — hãy đón chờ.</t>
                                        <t t-else="">Đang được giới thiệu tới cộng đồng.</t>
                                    </div>
                                </div>
                            </div>
                            <div class="uikick-hero-tags">
                                <span class="uikick-hero-tag">
                                    <svg width="14" height="14" fill="none" stroke="#05ce78" stroke-width="1.5" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                                    </svg>
                                    Sản phẩm nổi bật
                                </span>
                                <span class="uikick-hero-tag">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447 2.724A1 1 0 013 21.882V6.618a1 1 0 01.553-.894L9 3m0 17l6 3m-6-3V3m6 17l5.447 2.724A1 1 0 0021 21.882V6.618a1 1 0 00-.553-.894L15 3m0 17V3m0 0L9 3"/>
                                    </svg>
                                    <t t-esc="project.category"/>
                                </span>
                                <span class="uikick-hero-tag">
                                    <svg width="14" height="14" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" clip-rule="evenodd"
                                              d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"/>
                                    </svg>
                                    <t t-esc="project.location"/>
                                </span>
                            </div>
                        </div>

                        <aside class="uikick-hero-pledge">
                            <div class="uikick-interest-accent"/>
                            <div class="uikick-interest-count">
                                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                <span>
                                    <t t-if="project.status == 'ended'">Đã hoàn thành</t>
                                    <t t-elif="project.status == 'upcoming'">Sắp ra mắt</t>
                                    <t t-else="">Đang triển khai</t>
                                </span>
                            </div>
                            <p class="uikick-interest-label">Trạng thái dự án</p>

                            <div class="uikick-hero-meta-group">
                                <h4>Danh mục</h4>
                                <span class="uikick-category-badge"><t t-esc="project.category"/></span>
                            </div>
                            <div class="uikick-hero-meta-group">
                                <h4>Địa điểm</h4>
                                <div class="uikick-hero-location">
                                    <svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" clip-rule="evenodd"
                                              d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"/>
                                    </svg>
                                    <t t-esc="project.location"/>
                                </div>
                            </div>

                            <button class="uikick-btn-primary uikick-btn-block">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                                </svg>
                                Quan tâm ngay
                            </button>
                            <button type="button" class="uikick-btn-outline uikick-btn-block uikick-remind-btn">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                                <span class="uikick-remind-label">Để lại thông tin</span>
                            </button>
                            <p class="uikick-interest-help">Nhấn "Quan tâm" để theo dõi sản phẩm và nhận thông báo khi có cập nhật mới.</p>
                        </aside>
                    </div>
                </div>

                <!-- Platform info banner -->
                <div class="uikick-info-banner">
                    <div class="uikick-container uikick-info-grid">
                        <div class="uikick-info-item">
                            <div class="uikick-info-icon">
                                <svg width="14" height="14" viewBox="0 0 40 40" fill="none">
                                    <path d="M20 0C8.954 0 0 8.954 0 20s8.954 20 20 20 20-8.954 20-20S31.046 0 20 0z" fill="#05ce78"/>
                                    <path d="M13 10h5v8.5l7-8.5h6l-8 9.5L33 30h-6.5l-7.5-9V30H13V10z" fill="white"/>
                                </svg>
                            </div>
                            <p>Khám phá các sản phẩm sáng tạo từ khắp nơi trên thế giới.</p>
                        </div>
                        <div class="uikick-info-item">
                            <div class="uikick-info-icon">
                                <svg width="12" height="12" fill="none" stroke="#666" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                                </svg>
                            </div>
                            <p>Nhận thông báo cập nhật mới nhất từ tác giả khi bạn quan tâm sản phẩm.</p>
                        </div>
                        <div class="uikick-info-item">
                            <div class="uikick-info-icon">
                                <svg width="12" height="12" fill="none" stroke="#666" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <p>Kết nối trực tiếp với tác giả và cộng đồng yêu thích sản phẩm.</p>
                        </div>
                    </div>
                </div>

                <div class="uikick-container uikick-detail-body">
                    <!-- Tabs -->
                    <div class="uikick-tabs-row">
                        <nav class="uikick-tabs" id="uikick-tabs">
                            <t t-foreach="tabs" t-as="tab">
                                <a href="#" t-att-data-tab="tab"
                                   t-att-class="'uikick-tab active' if tab_index == 0 else 'uikick-tab'">
                                    <t t-esc="tab_labels.get(tab, tab)"/>
                                    <t t-if="tab == 'Comments'"><span class="uikick-tab-count">70</span></t>
                                </a>
                            </t>
                        </nav>
                        <div class="uikick-tabs-actions">
                            <button class="uikick-btn-primary">Quan tâm ngay</button>
                            <button type="button" class="uikick-btn-outline uikick-remind-btn">
                                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                                <span class="uikick-remind-label">Để lại thông tin</span>
                            </button>
                        </div>
                    </div>

                    <div class="uikick-detail-columns">
                        <!-- Left: TOC (decorative, matches the source React mock 1:1) -->
                        <aside class="uikick-toc-sidebar">
                            <nav>
                                <t t-foreach="toc_items" t-as="item">
                                    <span class="uikick-toc-item"><t t-esc="item"/></span>
                                </t>
                            </nav>
                        </aside>

                        <!-- Center: tab content -->
                        <main class="uikick-detail-main">
                            <div class="uikick-tab-content active" data-tab="Campaign">
                                <h2 class="uikick-section-title">Câu chuyện sản phẩm</h2>

                                <div class="uikick-story-text">
                                    <p>
                                        Được phát triển bởi <strong><t t-esc="project.creator"/></strong>, sản phẩm
                                        <strong><t t-esc="project.title"/></strong> ra đời từ nhu cầu thực tế của người dùng
                                        hiện đại — đơn giản, mạnh mẽ và đẹp mắt.
                                    </p>
                                    <p>
                                        Là một sản phẩm thuộc lĩnh vực <strong><t t-esc="project.category"/></strong>, đây tiếp tục
                                        là minh chứng cho cam kết mang đến trải nghiệm người dùng thực sự chất lượng.
                                    </p>

                                    <div class="uikick-feature-box">
                                        <h3>Tính năng nổi bật</h3>
                                        <div class="uikick-feature-grid">
                                            <t t-foreach="(project.description or '').split('|')" t-as="feat">
                                                <t t-if="feat.strip()">
                                                    <div class="uikick-feature-item">
                                                        <span class="uikick-feature-check">✓</span>
                                                        <span><t t-esc="feat.strip()"/></span>
                                                    </div>
                                                </t>
                                            </t>
                                        </div>
                                    </div>

                                    <p>
                                        Đội ngũ kỹ sư đã mất hơn 18 tháng để hoàn thiện từng chi tiết, từ hệ thống tản nhiệt
                                        cho đến trải nghiệm người dùng. Kết quả là một sản phẩm vượt trội hơn 40% so với
                                        thế hệ trước.
                                    </p>

                                    <div class="uikick-milestone-box">
                                        <div class="uikick-milestone-pct"><t t-esc="(project.category or '').upper()"/></div>
                                        <div class="uikick-milestone-meta">Một sản phẩm tiêu biểu đến từ <t t-esc="project.location"/>.</div>
                                    </div>

                                    <p>
                                        Chúng tôi sẽ thông báo cho bạn ngay khi sản phẩm sẵn sàng ra mắt. Đừng bỏ lỡ cơ hội
                                        trải nghiệm đầu tiên.
                                    </p>

                                    <div class="uikick-lead-form">
                                        <h3>
                                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                                            </svg>
                                            Để lại thông tin quan tâm
                                        </h3>
                                        <p class="uikick-lead-form-desc">Chúng tôi sẽ liên hệ với bạn ngay khi sản phẩm có thông tin mới nhất.</p>
                                        <div class="uikick-lead-form-row">
                                            <div class="uikick-lead-field">
                                                <label>Họ và tên <span class="uikick-required">*</span></label>
                                                <input type="text" name="lead_name" placeholder="Nguyễn Văn A"/>
                                            </div>
                                            <div class="uikick-lead-field">
                                                <label>Số điện thoại <span class="uikick-required">*</span></label>
                                                <input type="tel" name="lead_phone" placeholder="0912 345 678"/>
                                            </div>
                                        </div>
                                        <div class="uikick-lead-field">
                                            <label>Email <span class="uikick-required">*</span></label>
                                            <input type="email" name="lead_email" placeholder="example@email.com"/>
                                        </div>
                                        <div class="uikick-lead-field">
                                            <label>Ghi chú / Câu hỏi</label>
                                            <textarea name="lead_note" placeholder="Tôi quan tâm đến sản phẩm này vì..."/>
                                        </div>
                                        <button type="button" class="uikick-btn-primary uikick-btn-block">Gửi thông tin</button>
                                        <p class="uikick-lead-form-note">Thông tin của bạn được bảo mật và chỉ dùng để liên hệ về sản phẩm này.</p>
                                    </div>
                                </div>
                            </div>

                            <div class="uikick-tab-content" data-tab="Rewards">
                                <h2 class="uikick-section-title">Tính năng</h2>
                                <div class="uikick-reward-list">
                                    <t t-foreach="reward_tiers" t-as="tier">
                                        <div class="uikick-reward-card">
                                            <div class="uikick-reward-head">
                                                <div class="uikick-reward-title"><t t-esc="tier.title"/></div>
                                            </div>
                                            <p class="uikick-reward-desc"><t t-esc="tier.description"/></p>
                                            <div class="uikick-reward-meta">
                                                <span>Dự kiến hoàn thiện: <t t-esc="tier.estimated"/></span>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <t t-foreach="tabs" t-as="tab">
                                <t t-if="tab not in ('Campaign', 'Rewards')">
                                    <div class="uikick-tab-content" t-att-data-tab="tab">
                                        <div class="uikick-tab-placeholder">
                                            <div class="uikick-tab-placeholder-icon">📋</div>
                                            <p>Nội dung <t t-esc="tab_labels.get(tab, tab)"/> đang được cập nhật.</p>
                                        </div>
                                    </div>
                                </t>
                            </t>
                        </main>

                        <!-- Right: creator + share -->
                        <aside class="uikick-detail-side">
                            <div class="uikick-creator-card">
                                <div class="uikick-creator-head">
                                    <div class="uikick-creator-avatar"><t t-esc="(project.creator or '')[:1]"/></div>
                                    <div>
                                        <div class="uikick-creator-name"><t t-esc="project.creator"/></div>
                                        <div class="uikick-creator-role">Tác giả sản phẩm</div>
                                    </div>
                                </div>
                                <div class="uikick-creator-meta">
                                    <span><t t-esc="project.campaign_number or 1"/> sản phẩm đã đăng</span>
                                    <span>•</span>
                                    <span><t t-esc="project.location"/></span>
                                </div>
                                <p class="uikick-creator-bio">
                                    <t t-esc="project.creator"/> là đội ngũ kỹ sư và nhà thiết kế đam mê tạo ra những sản phẩm
                                    khiến bạn phải ngạc nhiên.
                                </p>
                                <button class="uikick-link-btn">Liên hệ tác giả</button>
                            </div>

                            <div class="uikick-support-box">
                                <h3>Chia sẻ sản phẩm</h3>
                                <div class="uikick-share-icons">
                                    <button type="button" aria-label="Chia sẻ trên X">𝕏</button>
                                    <button type="button" aria-label="Chia sẻ trên Facebook">f</button>
                                    <button type="button" aria-label="Chia sẻ trên LinkedIn">in</button>
                                    <button type="button" aria-label="Chia sẻ qua email">📧</button>
                                </div>
                            </div>
                        </aside>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
